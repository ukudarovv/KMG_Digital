APP_NAME=KMG Onboarding AI Module
APP_VERSION=0.1.0
ENVIRONMENT=development

FRONTEND_URL=http://localhost:5174

DATABASE_URL=postgresql://kmg_user:kmg_password@postgres:5432/kmg_onboarding

RISK_ENGINE_INTERVAL_MINUTES=30

BITRIX_WEBHOOK_URL=
BITRIX_BOT_ID=
BITRIX_HR_USER_ID=

CHAIRMAN_VIDEO_URL=https://team.kmg.kz/onboarding/welcome-video

LLM_ENABLED=true
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=700
LLM_TIMEOUT_SECONDS=90

DOCS_PATH=/docs
EMBEDDING_MODEL=nomic-embed-text
RAG_MIN_SCORE=0.35
RAG_SEARCH_LIMIT=5
